<!DOCTYPE html>
<html lang="en">
  <head>
    <!-- Standard meta tags -->
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{{ description }}">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="{{ client.domain }}{{ page.url }}">

    <!-- Open Graph -->
    <meta property="og:site_name" content="{{ client.name }}"/>
    <meta property="og:title" content="{{ title }}"/>
    <meta property="og:description" content="{{ description }}"/>
    <meta property="og:type" content="website"/>
    <meta property="og:url" content="{{ client.domain }}{{ page.url }}"/>
    <meta property="og:image" content="{{ client.domain }}/assets/images/hero_image.jpg"/>
    <meta property="og:image:secure_url" content="{{ client.domain }}/assets/images/hero_image.jpg"/>

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ title }}">
    <meta name="twitter:description" content="{{ description }}">
    <meta name="twitter:image" content="{{ client.domain }}/assets/images/hero_image.jpg">

    <!-- Favicons -->
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/favicons/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicons/favicon-32x32.png?v1">
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicons/favicon-16x16.png">
    <link rel="manifest" href="/assets/favicons/site.webmanifest">
    <meta name="msapplication-TileColor" content="#da532c">
    <meta name="theme-color" content="#ffffff">

    <!-- Sitewide Stylesheets and Scripts -->
    <link rel="stylesheet" href="/assets/css/styles.css">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Roboto:wght@400;700&display=swap">

    {% block head %}{% endblock %}

    <title>{{ title }}</title>

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "HomeAndConstructionBusiness",
        "name": "{{ client.name }}",
        "url": "{{ client.domain }}",
        "logo": "{{ client.domain }}/assets/images/kickers-logo-wordmark.svg",
        "image": "{{ client.domain }}/assets/images/hero_image.jpg",
        "description": "Charleston-area kitchen and bathroom remodeling built on quality craftsmanship, honest pricing, and dependable service.",
        "telephone": "{{ client.phone }}",
        "email": "{{ client.email }}",
        "priceRange": "$$",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "{{ client.address.city }}",
          "addressRegion": "{{ client.address.state }}",
          "addressCountry": "US"
        },
        "areaServed": [
          { "@type": "City", "name": "Charleston" },
          { "@type": "AdministrativeArea", "name": "South Carolina Low Country" }
        ],
        "openingHoursSpecification": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
            "opens": "07:00",
            "closes": "17:00"
          }
        ]
      }
    </script>

  </head>

  <body>
    {% include "components/header.njk" %}
    <main>
      {% block content %}{% endblock %}
    </main>
    {% include "components/footer.njk" %}
    <script src="https://cdn.jsdelivr.net/npm/@tailwindplus/elements@1" type="module"></script>
    <script type="module" src="/assets/js/main.js"></script>
  </body>
</html>
