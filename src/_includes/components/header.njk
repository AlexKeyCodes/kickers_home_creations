<header id="main-header" class="fixed inset-x-0 top-0 z-50 bg-brand-green transition-shadow duration-300">
  <nav aria-label="Global" class="flex items-center justify-between px-6 py-3">
    <div class="flex lg:flex-1">
      <a href="/" class="-m-1.5 p-1.5">
        <span class="sr-only">{{ client.name }}</span>
        <img src="assets/images/kickers-logo-wordmark-white.svg" alt="{{ client.name }} Logo" class="h-14 w-auto" />
      </a>
    </div>
    <div class="flex lg:hidden">
      <button type="button" command="show-modal" commandfor="mobile-menu" class="-m-2.5 inline-flex items-center justify-center rounded-md p-2.5 text-white">
        <span class="sr-only">Open main menu</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="size-6">
          <path d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
    </div>
    <div class="hidden lg:flex lg:gap-x-10">
      <a href="#services" class="text-lg text-white hover:text-brand-gold transition-colors">Services</a>
      {% if client.testimonials and client.testimonials.length %}<a href="#testimonials" class="text-lg text-white hover:text-brand-gold transition-colors">Reviews</a>{% endif %}
      <a href="#faq" class="text-lg text-white hover:text-brand-gold transition-colors">FAQ</a>
    </div>
    <div class="hidden lg:flex lg:flex-1 lg:justify-end lg:items-center lg:gap-x-6">
      <span class="flex items-center gap-2 text-lg font-semibold text-white whitespace-nowrap">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="size-5">
          <path d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        {{ client.address.city }}, {{ client.address.state }}
      </span>
      <a href="#contact" class="rounded-md bg-brand-gold px-4 py-3 text-base font-semibold text-white shadow-sm hover:bg-brand-gold-dark transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-gold">Get a Quote</a>
    </div>
  </nav>
  <el-dialog>
    <dialog id="mobile-menu" class="m-0 p-0 backdrop:bg-transparent lg:hidden">
      <div tabindex="0" class="fixed inset-0 focus:outline focus:outline-0">
        <el-dialog-panel class="fixed inset-y-0 right-0 z-50 w-full overflow-y-auto bg-white p-6 sm:max-w-sm sm:ring-1 sm:ring-gray-900/10">
          <div class="flex items-center justify-between">
            <a href="/" class="-m-1.5 p-1.5">
              <span class="sr-only">{{ client.name }}</span>
              <img src="assets/images/kickers-logo-wordmark.svg" alt="{{ client.name }} Logo" class="h-12 w-auto" />
            </a>
            <button type="button" command="close" commandfor="mobile-menu" class="-m-2.5 rounded-md p-2.5 text-gray-700">
              <span class="sr-only">Close menu</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="size-6">
                <path d="M6 18 18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </button>
          </div>
          <div class="mt-6 flow-root">
            <div class="-my-6 divide-y divide-gray-500/10">
              <div class="space-y-2 py-6">
                <a href="#services" class="-mx-3 block rounded-lg px-3 py-2 text-base/7 text-gray-900 hover:bg-gray-50">Services</a>
                {% if client.testimonials and client.testimonials.length %}<a href="#testimonials" class="-mx-3 block rounded-lg px-3 py-2 text-base/7 text-gray-900 hover:bg-gray-50">Reviews</a>{% endif %}
                <a href="#faq" class="-mx-3 block rounded-lg px-3 py-2 text-base/7 text-gray-900 hover:bg-gray-50">FAQ</a>
              </div>
              <div class="py-6 space-y-3">
                <span class="-mx-3 flex items-center justify-center gap-2 rounded-lg px-4 py-3 text-lg font-semibold text-brand-green text-center">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="size-5">
                    <path d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" stroke-linecap="round" stroke-linejoin="round" />
                    <path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                  {{ client.address.city }}, {{ client.address.state }}
                </span>
                <a href="#contact" class="-mx-3 block rounded-lg px-4 py-3 text-lg font-semibold text-white bg-brand-gold hover:bg-brand-gold-dark text-center">Get a Quote</a>
              </div>
            </div>
          </div>
        </el-dialog-panel>
      </div>
    </dialog>
  </el-dialog>
</header>
