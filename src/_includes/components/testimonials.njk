<!-- Testimonials Section -->
{% if client.testimonials and client.testimonials.length %}
<section id="testimonials" class="bg-brand-green py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-base font-semibold uppercase tracking-widest text-brand-gold">Reviews</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-white sm:text-4xl">What Our Clients Say</h2>
      <p class="mt-4 text-lg text-gray-100">Real feedback from homeowners around Charleston and the Low Country.</p>
    </div>

    <div class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-8 lg:max-w-none lg:grid-cols-3">
      {% for t in client.testimonials %}
        <figure class="flex h-full flex-col justify-between rounded-2xl bg-white p-8 shadow-sm">
          <div>
            <div class="flex gap-1 text-brand-gold">
              {% for s in range(0, t.rating or 5) %}
                <svg viewBox="0 0 20 20" fill="currentColor" class="size-5"><path d="M9.05 2.93c.3-.92 1.6-.92 1.9 0l1.37 4.22a1 1 0 0 0 .95.69h4.44c.97 0 1.37 1.24.59 1.81l-3.6 2.61a1 1 0 0 0-.36 1.12l1.37 4.22c.3.92-.75 1.69-1.54 1.12l-3.6-2.61a1 1 0 0 0-1.17 0l-3.6 2.61c-.79.57-1.84-.2-1.54-1.12l1.37-4.22a1 1 0 0 0-.36-1.12l-3.6-2.61c-.78-.57-.38-1.81.59-1.81h4.44a1 1 0 0 0 .95-.69l1.37-4.22Z"/></svg>
              {% endfor %}
            </div>
            <blockquote class="mt-6 text-base text-gray-700">"{{ t.quote }}"</blockquote>
          </div>
          <figcaption class="mt-6 flex items-center gap-4">
            <div class="flex size-10 items-center justify-center rounded-full bg-brand-green text-sm font-semibold uppercase text-white">{{ t.name | first }}</div>
            <div>
              <div class="font-semibold text-brand-dark">{{ t.name }}</div>
              {% if t.location %}<div class="text-sm text-gray-500">{{ t.location }}</div>{% endif %}
            </div>
          </figcaption>
        </figure>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}
