<!-- FAQ Section -->
<section id="faq" class="bg-white py-20 sm:py-28">
  <div class="mx-auto max-w-3xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-base font-semibold uppercase tracking-widest text-brand-gold">Questions</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-brand-dark sm:text-4xl">Frequently Asked Questions</h2>
      <p class="mt-4 text-lg text-gray-600">Placeholder answers to common questions. Replace with real content.</p>
    </div>

    <div class="mx-auto mt-12 divide-y divide-gray-200">
      {% for i in range(0, 5) %}
        <details class="group py-6">
          <summary class="flex cursor-pointer items-center justify-between text-lg font-semibold text-brand-dark marker:content-none">
            Frequently asked question #{{ i + 1 }}?
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-5 text-brand-gold transition-transform group-open:rotate-180">
              <path d="m6 9 6 6 6-6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </summary>
          <p class="mt-4 text-base text-gray-600">Placeholder answer to this question. Provide clear, helpful information for prospective customers here.</p>
        </details>
      {% endfor %}
    </div>
  </div>
</section>
