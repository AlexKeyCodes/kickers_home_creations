<section id="hero" class="bg-white">
  <div class="relative isolate overflow-hidden flex items-center hero-with-header">
    <div id="hero-slider" class="absolute inset-0 -z-10 size-full">
      <img src="assets/images/hero-bg-optimized.jpg" alt="" class="hero-slide absolute inset-0 size-full object-cover opacity-100 transition-opacity duration-1000 ease-in-out" />
      <img src="assets/images/hero-bg-2-optimized.jpg" alt="" class="hero-slide absolute inset-0 size-full object-cover opacity-0 transition-opacity duration-1000 ease-in-out" />
      <img src="assets/images/hero-bg-3-optimized.jpg" alt="" class="hero-slide absolute inset-0 size-full object-cover opacity-0 transition-opacity duration-1000 ease-in-out" />
    </div>
    <div class="absolute inset-0 -z-10 bg-brand-green opacity-70"></div>
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h1 class="text-balance text-4xl font-semibold tracking-tight text-white sm:text-7xl">{{ client.hero_title }}</h1>
        <p class="mt-8 text-pretty text-lg font-medium text-gray-100 sm:text-xl/8">{{ client.hero_subtitle }}</p>
        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="#contact" class="rounded-md bg-brand-gold px-6 py-3 text-base font-semibold text-brand-dark shadow-sm hover:bg-brand-gold-dark transition-colors">Get a Free Quote</a>
          <a href="#portfolio" class="rounded-md border border-white/70 px-6 py-3 text-base font-semibold text-white hover:bg-white/10 transition-colors">View Our Work</a>
        </div>
      </div>
    </div>
  </div>
</section>
