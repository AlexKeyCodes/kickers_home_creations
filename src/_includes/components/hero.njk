<section id="hero" class="relative isolate overflow-hidden flex items-center min-h-[75vh] pt-20 lg:pt-[5.5rem]">
  <img src="assets/images/hero_image.jpg" alt="Recently completed home by {{ client.restaurantName }}" class="absolute inset-0 -z-10 size-full object-cover" />
  <div class="absolute inset-0 -z-10 bg-gradient-to-b from-black/80 via-black/60 to-black/70"></div>
  <div class="mx-auto max-w-7xl px-6 lg:px-8 py-16">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-brand-gold">{{ client.address.city }}, {{ client.address.state }} &middot; Kitchen &amp; Bath Remodeling</p>
      <h1 class="mt-4 text-balance text-4xl font-semibold tracking-tight text-white sm:text-6xl lg:text-7xl">{{ client.hero_title }}</h1>
      <p class="mt-6 text-pretty text-lg font-medium text-gray-100 sm:text-xl/8">{{ client.hero_subtitle }}</p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#contact" class="w-full sm:w-auto rounded-md bg-brand-gold px-6 py-3 text-center text-base font-semibold text-white shadow-sm hover:bg-brand-gold-dark transition-colors">Get a Free Quote</a>
        <a href="#portfolio" class="w-full sm:w-auto rounded-md border border-white/70 px-6 py-3 text-center text-base font-semibold text-white hover:bg-white/10 transition-colors">View Our Work</a>
      </div>
    </div>
  </div>
</section>
