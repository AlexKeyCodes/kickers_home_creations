<!-- Services Section -->
<section id="services" class="bg-white py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-base font-semibold uppercase tracking-widest text-brand-gold">What We Do</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-brand-dark sm:text-4xl">Our Services</h2>
      <p class="mt-4 text-lg text-gray-600">A placeholder intro describing the range of construction and remodeling services we offer across the Charleston Low Country.</p>
    </div>

    <div class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-8 sm:grid-cols-2 lg:max-w-none lg:grid-cols-3">
      {% for i in range(0, 6) %}
        <div class="rounded-2xl border border-gray-200 bg-brand-cream/40 p-8 shadow-sm transition hover:shadow-md">
          <div class="flex size-12 items-center justify-center rounded-lg bg-brand-green text-white">
            <span class="text-lg font-semibold">{{ i + 1 }}</span>
          </div>
          <h3 class="mt-6 text-xl font-semibold text-brand-dark">Service Title {{ i + 1 }}</h3>
          <p class="mt-2 text-base text-gray-600">Placeholder description of this service. Replace with real copy about the work, materials, and value we provide.</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
