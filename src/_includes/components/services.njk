<!-- Services Section -->
<section id="services" class="bg-white py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-brand-gold">What We Do</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-brand-dark sm:text-4xl">Our Services</h2>
      <p class="mt-4 text-lg text-gray-600">From full kitchen and bath remodels to handyman work and real estate punch lists, we handle it across the Charleston Low Country.</p>
    </div>

    <div class="mx-auto mt-16 grid max-w-2xl grid-cols-1 items-center gap-12 lg:max-w-none lg:grid-cols-2 lg:gap-16">
      <!-- Service cards (stacked) -->
      <div class="space-y-5">
        {% for service in client.services %}
          <div class="flex items-start gap-5 rounded-2xl border border-gray-200 bg-brand-cream/40 p-6 shadow-sm transition hover:shadow-md">
            <div class="flex size-12 flex-none items-center justify-center rounded-lg bg-brand-green text-white">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="size-6">
                {% if service.icon == 'kitchen' %}
                  <rect x="3" y="4" width="18" height="16" rx="2" />
                  <circle cx="8" cy="9" r="1.4" /><circle cx="16" cy="9" r="1.4" />
                  <circle cx="8" cy="15" r="1.4" /><circle cx="16" cy="15" r="1.4" />
                {% elif service.icon == 'bath' %}
                  <path d="M4 12h16v3a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3v-3Z" />
                  <path d="M6 12V6a2 2 0 0 1 3.5-1.3" /><path d="M9 5.5h.01" />
                  <path d="M7 18l-1 2M18 18l1 2" />
                {% elif service.icon == 'handyman' %}
                  <path d="M21 3a6 6 0 0 1-8 8L5 19a2 2 0 1 1-3-3l8-8a6 6 0 0 1 8-8l-3.5 3.5L16 6l1.5 1.5L21 3Z" />
                {% elif service.icon == 'punchlist' %}
                  <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2" />
                  <rect x="9" y="3" width="6" height="4" rx="1" />
                  <path d="M9 13l2 2 4-4" />
                {% endif %}
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-semibold text-brand-dark">{{ service.title }}</h3>
              <p class="mt-1 text-base text-gray-600">{{ service.description }}</p>
            </div>
          </div>
        {% endfor %}
      </div>

      <!-- Image carousel -->
      <div id="services-carousel" class="relative mx-auto w-full max-w-md lg:max-w-none">
        <div class="relative aspect-[4/5] overflow-hidden rounded-2xl shadow-lg">
          {% for image in client.serviceImages %}
            <picture class="contents">
              <source srcset="{{ image.webp }}" type="image/webp" />
              <img src="{{ image.src }}" alt="{{ image.alt }}" loading="{{ 'eager' if loop.first else 'lazy' }}" decoding="async" class="services-slide absolute inset-0 size-full object-cover transition-opacity duration-700 ease-in-out {{ 'opacity-100' if loop.first else 'opacity-0' }}" />
            </picture>
          {% endfor %}

          <!-- Prev / Next -->
          <button type="button" data-carousel-prev aria-label="Previous image" class="absolute left-3 top-1/2 -translate-y-1/2 flex size-10 items-center justify-center rounded-full bg-black/40 text-white backdrop-blur-sm hover:bg-black/60 transition-colors">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-5"><path d="m15 18-6-6 6-6" /></svg>
          </button>
          <button type="button" data-carousel-next aria-label="Next image" class="absolute right-3 top-1/2 -translate-y-1/2 flex size-10 items-center justify-center rounded-full bg-black/40 text-white backdrop-blur-sm hover:bg-black/60 transition-colors">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-5"><path d="m9 18 6-6-6-6" /></svg>
          </button>
        </div>

        <!-- Dots -->
        <div class="mt-4 flex justify-center gap-2">
          {% for image in client.serviceImages %}
            <button type="button" data-carousel-dot="{{ loop.index0 }}" aria-label="Go to image {{ loop.index }}" class="size-2.5 rounded-full transition-colors {{ 'bg-brand-green' if loop.first else 'bg-gray-300' }}"></button>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>
