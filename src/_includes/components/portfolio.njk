<!-- Portfolio / Project Progression Section -->
<section id="portfolio" class="bg-brand-cream/50 py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-brand-gold">{{ client.projectSpotlight.eyebrow }}</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-brand-dark sm:text-4xl">{{ client.projectSpotlight.title }}</h2>
      <p class="mt-4 text-lg text-gray-600">{{ client.projectSpotlight.description }}</p>
    </div>

    <div class="mx-auto mt-16 grid max-w-md grid-cols-1 gap-10 sm:max-w-none sm:grid-cols-3 sm:gap-8">
      {% for step in client.projectSpotlight.steps %}
        <figure class="relative">
          <div class="relative aspect-[3/4] overflow-hidden rounded-2xl shadow-lg">
            <picture class="contents">
              <source srcset="{{ step.webp }}" type="image/webp" />
              <img src="{{ step.image }}" alt="{{ step.stage }} stage of fireplace feature wall by {{ client.name }}" loading="lazy" decoding="async" class="size-full object-cover" />
            </picture>
            <span class="absolute left-4 top-4 flex size-9 items-center justify-center rounded-full bg-brand-gold text-sm font-semibold text-white shadow">{{ loop.index }}</span>
          </div>

          {% if not loop.last %}
            <div class="absolute -right-6 top-[42%] z-10 hidden size-9 items-center justify-center rounded-full bg-brand-green text-white shadow-md sm:flex">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="size-4"><path d="m9 18 6-6-6-6" /></svg>
            </div>
          {% endif %}

          <figcaption class="mt-5">
            <h3 class="text-xl font-semibold text-brand-dark">{{ step.stage }}</h3>
            <p class="mt-1 text-base text-gray-600">{{ step.caption }}</p>
          </figcaption>
        </figure>
      {% endfor %}
    </div>
  </div>
</section>
