<!-- Quote / Contact Form Section -->
<section id="contact" class="bg-brand-cream/50 py-20 sm:py-28">
  <div class="mx-auto max-w-2xl px-6 lg:px-8">
    <div class="text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-brand-gold">Get Started</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-brand-dark sm:text-4xl">Request a Free Quote</h2>
      <p class="mt-4 text-lg text-gray-600">Tell us about your project and we'll get back to you with a free, no-obligation estimate.</p>
    </div>

    <form action="#" method="POST" class="mt-12 space-y-6 rounded-2xl bg-white p-8 shadow-sm ring-1 ring-gray-200 sm:p-10">
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        <div>
          <label for="name" class="block text-sm font-semibold text-brand-dark">Name</label>
          <input type="text" name="name" id="name" autocomplete="name" required
            class="mt-2 block w-full rounded-md border-0 px-3.5 py-2.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-brand-green" />
        </div>
        <div>
          <label for="phone" class="block text-sm font-semibold text-brand-dark">Phone</label>
          <input type="tel" name="phone" id="phone" autocomplete="tel"
            class="mt-2 block w-full rounded-md border-0 px-3.5 py-2.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-brand-green" />
        </div>
      </div>

      <div>
        <label for="email" class="block text-sm font-semibold text-brand-dark">Email</label>
        <input type="email" name="email" id="email" autocomplete="email" required
          class="mt-2 block w-full rounded-md border-0 px-3.5 py-2.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-brand-green" />
      </div>

      <div>
        <label for="project_type" class="block text-sm font-semibold text-brand-dark">Project Type</label>
        <select name="project_type" id="project_type" required
          class="mt-2 block w-full rounded-md border-0 px-3.5 py-2.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-brand-green">
          <option value="" disabled selected>Select a project type</option>
          {% for service in client.services %}
            <option value="{{ service.title }}">{{ service.title }}</option>
          {% endfor %}
          <option value="Other">Other</option>
        </select>
      </div>

      <div>
        <label for="message" class="block text-sm font-semibold text-brand-dark">Message</label>
        <textarea name="message" id="message" rows="4"
          class="mt-2 block w-full rounded-md border-0 px-3.5 py-2.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-brand-green"
          placeholder="Tell us a bit about what you have in mind..."></textarea>
      </div>

      <button type="submit"
        class="w-full rounded-md bg-brand-gold px-6 py-3 text-base font-semibold text-white shadow-sm hover:bg-brand-gold-dark transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-gold">
        Request Quote
      </button>
    </form>
  </div>
</section>
